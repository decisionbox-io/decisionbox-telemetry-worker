{
  "name": "decisionbox-telemetry-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create decisionbox-telemetry",
    "db:migrate": "wrangler d1 execute decisionbox-telemetry --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute decisionbox-telemetry --local --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0",
    "@cloudflare/workers-types": "^4.0.0"
  }
}
